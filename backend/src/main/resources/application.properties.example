spring.datasource.url=jdbc:postgresql://localhost:5432/secondbrain_db
spring.datasource.username=your_db_username
spring.datasource.password=your_db_password

jwt.secret=your_jwt_secret_here

spring.ai.google.gemini.api-key=${SPRING_AI_GOOGLE_GEMINI_API_KEY}
spring.ai.google.gemini.model=gemini-2.5-flash-lite
spring.ai.google.gemini.endpoint=https://generativelanguage.googleapis.com/v1beta/models/
